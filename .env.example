# Selects the active generation backend: mock, openai, gemini, or anthropic.
# You can keep provider keys in .env.local, then switch only this value.
LLM_PROVIDER=mock

# Required when LLM_PROVIDER=openai.
OPENAI_API_KEY=

# Optional. Defaults to gpt-5.5 when LLM_PROVIDER=openai.
OPENAI_MODEL=gpt-5.5

# Required when LLM_PROVIDER=gemini.
GEMINI_API_KEY=

# Optional. Defaults to gemini-2.5-flash when LLM_PROVIDER=gemini.
GEMINI_MODEL=gemini-2.5-flash

# Required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# Optional. Defaults to claude-haiku-4-5-20251001 when LLM_PROVIDER=anthropic.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional. Set to 1 to log safe LLM response metadata for debugging.
DEBUG_LLM_RESPONSE=0

# RAG PoC Phase 1-A retrieval settings.
# Embeddings use OPENAI_API_KEY above. Do not commit real API keys.
RAG_EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# RAG PoC Phase 1-C grounded generation settings.
# Phase 1-C expects heading-aware-v1 / Top 5 based on Phase 1-A / 1-B evaluation.
RAG_CHUNK_STRATEGY=heading-aware-v1
RAG_TOP_K=5
